# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration - TiDB
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_USER=your-tidb-username
DB_PASS=your-tidb-password
DB_NAME=kitrijaya_db
DB_PORT=4000
DB_SSL=true

# Jika menggunakan TiDB Self-Hosted atau lokal:
# DB_HOST=localhost
# DB_PORT=4000
# DB_SSL=false

# JWT Secret (generate random string untuk production)
JWT_SECRET=your-secure-jwt-secret-here

# Google Places API (opsional, untuk reviews)
GOOGLE_PLACES_API_KEY=your-google-api-key
GOOGLE_PLACE_ID=your-place-id