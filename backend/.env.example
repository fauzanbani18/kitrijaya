# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (gunakan database hosting seperti PlanetScale, Railway, atau Aiven)
DB_HOST=your-database-host
DB_USER=your-database-user
DB_PASS=your-database-password
DB_NAME=kitrijaya_db
DB_PORT=3306

# JWT Secret (generate random string untuk production)
JWT_SECRET=your-secure-jwt-secret-here

# Google Places API (opsional, untuk reviews)
GOOGLE_PLACES_API_KEY=your-google-api-key
GOOGLE_PLACE_ID=your-place-id